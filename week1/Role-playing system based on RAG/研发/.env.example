# ==================== 应用基础信息 ====================
RAG_APP_NAME=RAG Role-Play System          # 应用名称，显示在 API 文档标题中
RAG_APP_ENV=dev                            # 运行环境：dev（开发）/ prod（生产）
RAG_APP_DEBUG=true                         # 调试模式：true 开启详细报错信息，生产环境建议 false

# ==================== 数据库连接 ====================
RAG_MYSQL_DSN=mysql+pymysql://root:*@localhost:3306/rag_roleplay  # MySQL 连接串（用户名:密码@地址:端口/库名）
RAG_REDIS_URL=redis://localhost:6379/0                                # Redis 地址，用于存储短期对话记忆和角色槽位
RAG_MILVUS_URI=http://localhost:19530                                 # Milvus 向量数据库地址（本地 Docker 或远程服务器）
RAG_MILVUS_ENABLED=false                                              # 是否启用 Milvus 向量检索（false 时 RAG 不可用）
RAG_MILVUS_COLLECTION=character_knowledge                             # Milvus 集合名前缀，实际集合名为 character_knowledge_{角色ID}

# ==================== 大模型 / Embedding 配置 ====================
RAG_LLM_PROVIDER=siliconflow                          # 大模型提供商：mock（模拟）/ siliconflow / openai / vllm / sglang
RAG_LLM_MODEL_NAME=deepseek-ai/DeepSeek-V3            # 大模型名称，用于对话生成和 Query Rewrite
RAG_OPENAI_API_BASE=https://api.siliconflow.cn/v1     # OpenAI 兼容 API 地址（LLM + Embedding 共用）
RAG_OPENAI_API_KEY=                                    # API 密钥（必填，否则无法调用 LLM 和 Embedding）
RAG_SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1 # SiliconFlow 平台备用地址

# ==================== 用户登录鉴权（JWT） ====================
RAG_JWT_SECRET=*     # JWT 签名密钥，生产环境必须改成随机长字符串
RAG_JWT_EXPIRE_MINUTES=1440                # 登录 Token 有效期（分钟），1440 = 24 小时

# ==================== 对话与检索参数 ====================
RAG_SHORT_MEMORY_ROUNDS=20                 # 短期记忆保留的最近对话轮数（每轮 = 一问一答）
RAG_RETRIEVAL_TOP_K=8                      # 混合检索返回的最相关文档片段数量
RAG_RERANK_TOP_K=5                         # 重排序后保留的最终结果数量
RAG_MAX_CONCURRENT_ROLES_PER_USER=3        # 每个用户最多同时与几个角色对话（超出会踢掉最久未活跃的）
RAG_ACTIVE_ROLE_IDLE_SECONDS=3600          # 角色会话空闲超时（秒），超过后视为不活跃，可被新角色替换

# ==================== 文件存储 ====================
RAG_UPLOAD_DIR=uploads                     # 用户上传知识库文件的存储目录
